  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mago Gonzalo</title>

  <style>
    body {
      margin: 0;
      background: #0f0f0f;
      color: white;
      font-family: Arial, sans-serif;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
      text-align: center;
    }

    .container {
      max-width: 700px;
      padding: 20px;
    }

    h1 {
      font-size: 4rem;
      margin-bottom: 10px;
    }

    p {
      font-size: 1.3rem;
      opacity: 0.8;
    }

    .button {
      display: inline-block;
      margin-top: 30px;
      padding: 14px 28px;
      background: white;
      color: black;
      text-decoration: none;
      border-radius: 999px;
      font-weight: bold;
    }

    .button:hover {
      opacity: 0.8;
    }
